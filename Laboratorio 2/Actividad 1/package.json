{
  "name": "custom-array-methods",
  "version": "1.0.0",
  "description": "Custom implementations of JavaScript array methods (map, reduce, filter, forEach) demonstrating functional programming principles",
  "main": "src/index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "javascript",
    "array-methods",
    "functional-programming",
    "custom-map",
    "custom-reduce",
    "custom-filter",
    "custom-forEach"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "fast-check": "^3.16.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}